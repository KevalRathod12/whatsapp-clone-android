<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- Profile Avatar Circle -->
    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:src="@android:drawable/ic_menu_gallery"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_bg"
        android:clipToOutline="true"
        android:tint="#FFFFFF"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Contact Name -->
    <TextView
        android:id="@+id/txtName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Rahul"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="#111111"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/imgProfile"
        app:layout_constraintTop_toTopOf="@id/imgProfile"
        app:layout_constraintEnd_toStartOf="@id/txtTime"/>

    <!-- Time on the right -->
    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:45 AM"
        android:textSize="11sp"
        android:textColor="#8696A0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/txtName"
        app:layout_constraintBaseline_toBaselineOf="@id/txtName"/>

    <!-- Last message preview -->
    <TextView
        android:id="@+id/txtMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tap to chat"
        android:textColor="#8696A0"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toEndOf="@id/imgProfile"
        app:layout_constraintTop_toBottomOf="@id/txtName"
        app:layout_constraintEnd_toStartOf="@id/badge"/>

    <!-- Unread Count Badge -->
    <TextView
        android:id="@+id/badge"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:gravity="center"
        android:text="2"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/badge_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/txtMessage"
        app:layout_constraintBottom_toBottomOf="@id/txtMessage"/>

</androidx.constraintlayout.widget.ConstraintLayout>
