<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base theme -->
    <style name="Theme.WhatsappClone" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- WhatsApp Primary Green -->
        <item name="colorPrimary">#075E54</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">#054C44</item>

        <!-- Toolbar icons color -->
        <item name="android:navigationBarColor">#000000</item>

        <!-- Disable default actionbar (we use custom toolbar) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

    </style>

</resources>
